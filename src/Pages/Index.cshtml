@page
@model IndexModel
@{
    ViewData["Title"] = "Home";
}

<style>
    .hero {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 80px 20px;
        text-align: center;
        border-radius: 12px;
        margin-bottom: 40px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.2);
    }
    .hero h1 {
        font-size: 3.5em;
        margin-bottom: 10px;
        font-weight: 300;
    }
    .hero p {
        font-size: 1.3em;
        opacity: 0.9;
    }
    .badge-pill {
        display: inline-block;
        padding: 6px 16px;
        background: rgba(255,255,255,0.2);
        border-radius: 20px;
        margin: 5px;
        font-size: 0.9em;
    }
    .stack {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 20px;
        margin-top: 40px;
    }
    .card-tile {
        background: white;
        padding: 30px 20px;
        border-radius: 10px;
        text-align: center;
        box-shadow: 0 4px 15px rgba(0,0,0,0.08);
        transition: transform 0.2s;
    }
    .card-tile:hover {
        transform: translateY(-5px);
    }
    .card-tile .icon {
        font-size: 3em;
        margin-bottom: 10px;
    }
    .card-tile h3 {
        margin: 10px 0 5px;
        color: #333;
    }
    .card-tile p {
        color: #777;
        font-size: 0.95em;
    }
</style>

<div class="hero">
    <h1>Deployed via OIDC</h1>
    <p>.NET 10 on Azure App Service · GitHub Actions · Terraform</p>
    <div style="margin-top: 25px;">
        <span class="badge-pill">Zero Secrets</span>
        <span class="badge-pill">Federated Identity</span>
        <span class="badge-pill">IaC Managed</span>
    </div>
</div>

<div class="stack">
    <div class="card-tile">
        <div class="icon">🔐</div>
        <h3>OIDC Auth</h3>
        <p>Short-lived tokens, no static secrets in GitHub</p>
    </div>
    <div class="card-tile">
        <div class="icon">🏗️</div>
        <h3>Terraform</h3>
        <p>Infrastructure provisioned and managed as code</p>
    </div>
    <div class="card-tile">
        <div class="icon">🚀</div>
        <h3>CI/CD</h3>
        <p>Build, test, deploy automated via GitHub Actions</p>
    </div>
    <div class="card-tile">
        <div class="icon">☁️</div>
        <h3>Azure</h3>
        <p>Linux App Service, .NET 10 runtime, B1 plan</p>
    </div>
</div>

<div style="text-align: center; margin-top: 50px; color: #888;">
    <p>Built by <strong>skybit9</strong> · <a href="https://github.com/skybit9/dotnet-azure-oidc">View source</a></p>
</div>